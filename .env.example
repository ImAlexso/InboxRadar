# Microsoft Entra app registration
CLIENT_ID=00000000-0000-0000-0000-000000000000

# Para el laboratorio con una cuenta Outlook/Hotmail personal:
AUTHORITY_TENANT=consumers

# En la futura versión corporativa se sustituirá por el tenant ID de la empresa.

# Opcional: fuerza el navegador usado al abrir correos.
# Si se omite, se usa el navegador predeterminado del sistema.
# INBOX_RADAR_BROWSER_PATH=C:/Program Files/Google/Chrome/Application/chrome.exe
